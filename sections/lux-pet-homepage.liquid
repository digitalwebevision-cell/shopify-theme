{%- style -%}
  .lph-{{ section.id }} {
    --lph-sage: #4A7C59;
    --lph-sage-dark: #3A6147;
    --lph-sage-light: #EAF1EC;
    --lph-white: #FFFFFF;
    --lph-gray: #F7F7F5;
    --lph-ink: #1A1A1A;
    --lph-ink-soft: #6B6B6B;
    --lph-blue-dark: #1B2A3B;
    --lph-blue-darker: #0F1922;
    --lph-radius: 8px;
    --lph-radius-lg: 16px;
    --lph-font-heading: var(--font-heading-family, 'Playfair Display', Georgia, serif);
    --lph-font-body: var(--font-body-family, 'Inter', -apple-system, sans-serif);
    font-family: var(--lph-font-body);
    background-color: var(--lph-white);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .lph-{{ section.id }} .lph__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .lph-{{ section.id }} h2,
  .lph-{{ section.id }} h3 {
    font-family: var(--lph-font-heading);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--lph-ink);
    margin: 0;
  }

  /* --- TRUST BAR --- */
  .lph-{{ section.id }} .lph__trust-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    background-color: var(--lph-gray);
    border-radius: var(--lph-radius-lg);
    padding: 32px 24px;
    margin-bottom: 64px;
  }

  .lph-{{ section.id }} .lph__trust-item {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .lph-{{ section.id }} .lph__trust-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--lph-sage-light);
    border-radius: 50%;
    color: var(--lph-sage);
  }

  .lph-{{ section.id }} .lph__trust-icon svg {
    width: 22px;
    height: 22px;
  }

  .lph-{{ section.id }} .lph__trust-text {
    font-size: 14px;
    font-weight: 500;
    color: var(--lph-ink);
    line-height: 1.35;
  }

  /* --- CATEGORIAS --- */
  .lph-{{ section.id }} .lph__section-heading {
    text-align: center;
    font-size: clamp(26px, 3.5vw, 38px);
    margin-bottom: 40px;
  }

  .lph-{{ section.id }} .lph__categories {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    margin-bottom: 72px;
  }

  .lph-{{ section.id }} .lph__category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    padding: 32px 16px;
    background-color: var(--lph-white);
    border: 1px solid #E4E4E0;
    border-radius: var(--lph-radius-lg);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .lph-{{ section.id }} .lph__category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(74, 124, 89, 0.15);
    border-color: var(--lph-sage);
  }

  .lph-{{ section.id }} .lph__category-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--lph-sage-light);
    border-radius: 50%;
    color: var(--lph-sage);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .lph-{{ section.id }} .lph__category-card:hover .lph__category-icon {
    background-color: var(--lph-sage);
    color: var(--lph-white);
  }

  .lph-{{ section.id }} .lph__category-icon svg {
    width: 30px;
    height: 30px;
  }

  .lph-{{ section.id }} .lph__category-label {
    font-family: var(--lph-font-heading);
    font-size: 17px;
    font-weight: 600;
    color: var(--lph-ink);
  }

  /* --- BANNER CÃES VS GATOS --- */
  .lph-{{ section.id }} .lph__split-banner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 72px;
  }

  .lph-{{ section.id }} .lph__split-panel {
    position: relative;
    border-radius: var(--lph-radius-lg);
    padding: 56px 40px;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    overflow: hidden;
  }

  .lph-{{ section.id }} .lph__split-panel--dogs {
    background: linear-gradient(135deg, var(--lph-sage) 0%, var(--lph-sage-dark) 100%);
  }

  .lph-{{ section.id }} .lph__split-panel--cats {
    background: linear-gradient(135deg, var(--lph-blue-dark) 0%, var(--lph-blue-darker) 100%);
  }

  .lph-{{ section.id }} .lph__split-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 12px;
  }

  .lph-{{ section.id }} .lph__split-heading {
    font-size: clamp(28px, 3vw, 36px);
    color: var(--lph-white);
    margin-bottom: 14px;
  }

  .lph-{{ section.id }} .lph__split-text {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    max-width: 380px;
    margin-bottom: 28px;
  }

  .lph-{{ section.id }} .lph__split-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background-color: var(--lph-white);
    color: var(--lph-ink);
    font-family: var(--lph-font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    border-radius: var(--lph-radius);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .lph-{{ section.id }} .lph__split-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  /* --- PORQUÊ A LUX PET --- */
  .lph-{{ section.id }} .lph__why {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .lph-{{ section.id }} .lph__why-heading {
    font-size: clamp(26px, 3.5vw, 36px);
    margin-bottom: 24px;
  }

  .lph-{{ section.id }} .lph__checklist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .lph-{{ section.id }} .lph__checklist-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 16px;
    color: var(--lph-ink-soft);
    line-height: 1.5;
  }

  .lph-{{ section.id }} .lph__check-icon {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--lph-sage);
    color: var(--lph-white);
    border-radius: 50%;
  }

  .lph-{{ section.id }} .lph__check-icon svg {
    width: 14px;
    height: 14px;
  }

  .lph-{{ section.id }} .lph__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .lph-{{ section.id }} .lph__stat-card {
    background-color: var(--lph-gray);
    border-radius: var(--lph-radius-lg);
    padding: 28px 20px;
    text-align: center;
  }

  .lph-{{ section.id }} .lph__stat-number {
    font-family: var(--lph-font-heading);
    font-size: clamp(28px, 3vw, 34px);
    font-weight: 700;
    color: var(--lph-sage);
    margin-bottom: 6px;
    display: block;
  }

  .lph-{{ section.id }} .lph__stat-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--lph-ink-soft);
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 989px) {
    .lph-{{ section.id }} .lph__categories {
      grid-template-columns: repeat(3, 1fr);
    }

    .lph-{{ section.id }} .lph__why {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 749px) {
    .lph-{{ section.id }} .lph__trust-bar {
      grid-template-columns: repeat(2, 1fr);
    }

    .lph-{{ section.id }} .lph__categories {
      grid-template-columns: repeat(2, 1fr);
    }

    .lph-{{ section.id }} .lph__split-banner {
      grid-template-columns: 1fr;
    }

    .lph-{{ section.id }} .lph__stats {
      grid-template-columns: 1fr 1fr;
    }
  }
{%- endstyle -%}

