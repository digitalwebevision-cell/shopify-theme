{% comment %}LUX PET — Homepage Custom Section{% endcomment %}

<!-- TRUST BAR -->
<div class="lp-trust-bar">
  <div class="lp-container">
    <div class="lp-trust-grid">
      <div class="lp-trust-item">
        <div class="lp-trust-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A7C59" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 4v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
        <div class="lp-trust-txt"><strong>Envio grátis</strong><span>Acima de €45</span></div>
      </div>
      <div class="lp-trust-item">
        <div class="lp-trust-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A7C59" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></div>
        <div class="lp-trust-txt"><strong>Qualidade garantida</strong><span>Produtos testados</span></div>
      </div>
      <div class="lp-trust-item">
        <div class="lp-trust-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A7C59" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg></div>
        <div class="lp-trust-txt"><strong>30 dias devolução</strong><span>Sem complicações</span></div>
      </div>
      <div class="lp-trust-item">
        <div class="lp-trust-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A7C59" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="11" width="22" height="11" rx="2" ry="2"/><path d="M1 11V7a2 2 0 0 1 2-2h18a2 2 0 0 1 2 2v4"/><line x1="12" y1="11" x2="12" y2="22"/></svg></div>
        <div class="lp-trust-txt"><strong>Pagamento seguro</strong><span>MB Way, Visa, PayPal</span></div>
      </div>
    </div>
  </div>
</div>

